# ============================================================
# momentum-bot – Umgebungsvariablen
# ============================================================
# Kopiere diese Datei als ".env" und trage deine echten Werte ein.
# NIEMALS die .env-Datei committen! Sie ist in .gitignore.
# Auf Railway: Werte unter Service > Variables eintragen.
# ============================================================

# IG API Zugangsdaten (Demo-Konto)
IG_API_KEY=dein_ig_api_key_hier
IG_USERNAME=deine@email.de
IG_PASSWORD=dein_ig_passwort
IG_ACC_TYPE=DEMO
IG_ACC_NUMBER=deine_kontonummer
